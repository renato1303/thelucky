{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "preinstall": "node -e \"try{require('fs').unlinkSync('package-lock.json')}catch(e){}try{require('fs').unlinkSync('yarn.lock')}catch(e){}if(!((process.env.npm_config_user_agent||'').startsWith('pnpm/')||(process.env.npm_config_user_agent||'').startsWith('pnpm'))){console.error('Use pnpm instead');process.exit(1)}\"",
    "build:libs": "pnpm --filter \"./lib/**\" run build",
    "build:api": "pnpm --filter \"./artifacts/api-server\" run build",
    "build": "pnpm run build:libs && pnpm run build:api && pnpm run typecheck",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "@types/react": "~19.1.17",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "stripe": "^22.0.0",
    "stripe-replit-sync": "^1.0.0"
  }
}
