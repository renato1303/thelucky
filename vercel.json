{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter \"./lib/**\" run build && pnpm --filter \"@workspace/api-server\" run build",
  "outputDirectory": "artifacts/api-server/dist",
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production",
    "PNPM_HOME": "/vercel/.pnpm"
  }
}